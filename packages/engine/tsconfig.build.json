{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.browser.test.ts", "src/__test__/**"],
  "references": [
    { "path": "../schemas/tsconfig.build.json" },
    { "path": "../wcag/tsconfig.build.json" }
  ]
}
