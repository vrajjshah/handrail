{
  "name": "@handrail/wcag",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "All 55 WCAG 2.2 A/AA success criteria as typed records, plus the coverage matrix that makes Handrail's reporting honest.",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@handrail/schemas": "workspace:*"
  },
  "devDependencies": {
    "axe-core": "^4.12.1"
  },
  "scripts": {
    "axe-map": "tsx src/scripts/generate-axe-map.ts"
  }
}
